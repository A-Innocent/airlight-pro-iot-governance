      <aliases enabled='yes' />
      <column caption='Spike Rate %' datatype='real' name='[Calculation_0521223723237376]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [is_thermal_spike] = TRUE THEN 1 ELSE 0 END) / COUNT([telemetry_key]) * 100' />
      </column>
      <column caption='Global Avg Temperature' datatype='real' name='[Calculation_0521223729364993]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED : AVG([temperature_celsius])}' />
      </column>
      <column caption='Store vs Global Diff' datatype='real' name='[Calculation_0521223729467394]' role='measure' type='quantitative'>
